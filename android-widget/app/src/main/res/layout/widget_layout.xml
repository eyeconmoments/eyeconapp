<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header: tap to refresh -->
    <TextView
        android:id="@+id/tv_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👁 Eyecon Moments"
        android:textColor="#C1A76A"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <!-- Who's clocked in -->
    <TextView
        android:id="@+id/tv_clocked_in"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Loading…"
        android:textColor="#E0E8F0"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.3" />

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:paddingTop="6dp">

        <TextView
            android:id="@+id/btn_clock_in"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:background="@drawable/btn_green"
            android:gravity="center"
            android:text="CLOCK IN"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_clock_out"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:background="@drawable/btn_red"
            android:gravity="center"
            android:text="CLOCK OUT"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Last updated -->
    <TextView
        android:id="@+id/tv_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="↻ tap title to refresh"
        android:textColor="#607080"
        android:textSize="10sp"
        android:paddingTop="4dp" />

</LinearLayout>
